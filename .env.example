# Optional research / data provider API keys (never required for backend startup).
# Copy to deployment.env, .env.local, or another gitignored file. Never use NEXT_PUBLIC_* for these.

# Macro / official
# SEC_USER_AGENT=YourOrg contact@example.com
# FRED_API_KEY=
# BLS_API_KEY=

# Market data / fundamentals
# ALPHA_VANTAGE_API_KEY=
# FINNHUB_API_KEY=
# FMP_API_KEY=
# TWELVE_DATA_API_KEY=
# TIINGO_API_KEY=
# EODHD_API_KEY=
# NASDAQ_DATA_LINK_API_KEY=
# POLYGON_API_KEY=
# MASSIVE_API_KEY=

# News
# GUARDIAN_API_KEY=
# NEWSAPI_KEY=
# MEDIASTACK_API_KEY=

# Crypto
# COINGECKO_API_KEY=
# COINMARKETCAP_API_KEY=

# Sports / odds
# THE_ODDS_API_KEY=
# FOOTBALL_DATA_API_KEY=
# API_FOOTBALL_KEY=
# API_SPORTS_KEY=
# SPORTMONKS_API_KEY=

# Alpaca (paper-first defaults; live requires deliberate operator approval)
# ALPACA_API_KEY=
# ALPACA_API_SECRET=
# ALPACA_BASE_URL=https://paper-api.alpaca.markets
# ALPACA_DATA_BASE_URL=https://data.alpaca.markets
# ALPACA_DATA_FEED=iex
# ALPACA_TRADING_MODE=paper
# PERSONAL_LIVE_APPROVED=false
# Legacy alias also honored by tooling:
# STRATEGY_VALIDATOR_PERSONAL_LIVE_APPROVED=false

# Alpaca env indirection (optional; used by some deployments)
# STRATEGY_VALIDATOR_ALPACA_API_KEY_ID_ENV=APCA_API_KEY_ID
# STRATEGY_VALIDATOR_ALPACA_API_SECRET_KEY_ENV=APCA_API_SECRET_KEY
# APCA_API_KEY_ID=
# APCA_API_SECRET_KEY=
