# Sample environment for operators (copy to a secure secrets manager in real deployments).
# Paths shown are placeholders — replace with deployment-specific values.

# --- Pilot probe (optional; non-production burn-in) ---
# PILOT_PROBE_SYMBOL=SPY

# --- Core runtime ---
# STRATEGY_VALIDATOR_MODE=PRODUCTION
# STRATEGY_VALIDATOR_LEDGER_DB_PATH=C:/absolute/path/to/forensic_ledger.sqlite3

# --- Market-data policy (fail-closed defaults in production) ---
# STRATEGY_VALIDATOR_ALLOW_PROVISIONAL_MARKET_DATA=False
# STRATEGY_VALIDATOR_ALLOW_SNAPSHOT_MARKET_DATA=False
# STRATEGY_VALIDATOR_ALLOW_MARKET_DATA_FALLBACK=False
# STRATEGY_VALIDATOR_STRICT_PRODUCTION_MODE=True
# STRATEGY_VALIDATOR_LIVE_MARKET_DATA_FRESHNESS_THRESHOLD_SECONDS=60
# STRATEGY_VALIDATOR_LIVE_FRESHNESS_MARKET_HOURS_PROFILE=DISABLED
# STRATEGY_VALIDATOR_LIVE_FRESHNESS_OFF_HOURS_THRESHOLD_SECONDS=3600

# --- Provider resilience ---
# STRATEGY_VALIDATOR_MARKET_DATA_PROVIDER_MAX_RETRIES=1
# STRATEGY_VALIDATOR_MARKET_DATA_CIRCUIT_BREAKER_THRESHOLD=2
# STRATEGY_VALIDATOR_MARKET_DATA_CIRCUIT_COOLDOWN_SECONDS=300
# STRATEGY_VALIDATOR_MARKET_DATA_VENDOR_OUTAGE_CIRCUIT_POLICY=STANDARD
# STRATEGY_VALIDATOR_MARKET_DATA_VENDOR_OUTAGE_CIRCUIT_POLICY=LENIENT_TRANSIENT_5XX

# --- Alpaca Market Data v2 (real US equities snapshot; borrow not included) ---
# STRATEGY_VALIDATOR_ALPACA_MARKET_DATA_ENABLED=True
# STRATEGY_VALIDATOR_ALPACA_DATA_BASE_URL=https://data.alpaca.markets
# STRATEGY_VALIDATOR_ALPACA_PROVIDER_ID=alpaca_data_v2
# STRATEGY_VALIDATOR_ALPACA_ENABLE_BORROW_FROM_TRADING_API=True
# STRATEGY_VALIDATOR_ALPACA_TRADING_BASE_URL=https://paper-api.alpaca.markets
# STRATEGY_VALIDATOR_ALPACA_ETB_BORROW_COST_BPS=20
# STRATEGY_VALIDATOR_ALPACA_HTB_BORROW_COST_BPS=300
# APCA_API_KEY_ID=
# APCA_API_SECRET_KEY=

# --- HTTP JSON live connector (optional skeleton) ---
# STRATEGY_VALIDATOR_HTTP_MARKET_DATA_ENABLED=True
# STRATEGY_VALIDATOR_HTTP_MARKET_DATA_PROVIDER_ID=my_vendor_feed
# STRATEGY_VALIDATOR_HTTP_MARKET_DATA_LIQUIDITY_URL_TEMPLATE=http://127.0.0.1:8080/liquidity/{asset_id}
# STRATEGY_VALIDATOR_HTTP_MARKET_DATA_BORROW_URL_TEMPLATE=http://127.0.0.1:8080/borrow/{asset_id}
# STRATEGY_VALIDATOR_HTTP_MARKET_DATA_API_KEY_ENV_VAR=MY_MARKET_DATA_API_KEY
# MY_MARKET_DATA_API_KEY=
# STRATEGY_VALIDATOR_HTTP_MARKET_DATA_TIMEOUT_SECONDS=10

# --- Empirical calibration (artifact required when CALIBRATED) ---
# STRATEGY_VALIDATOR_CAPACITY_IMPACT_MODEL=HEURISTIC
# STRATEGY_VALIDATOR_CALIBRATION_ARTIFACT_PATH=C:/absolute/path/calibration_v1.json
# STRATEGY_VALIDATOR_CALIBRATION_MINIMUM_VALIDATION_SCORE=0.0
# STRATEGY_VALIDATOR_CALIBRATION_REJECT_FLAT_CURVE_SPREAD_BPS_BELOW=0.0
# STRATEGY_VALIDATOR_CALIBRATION_REQUIRE_TRAINING_RUN_ID=False
# STRATEGY_VALIDATOR_CALIBRATION_REQUIRE_EMPIRICAL_CURVE_IN_PRODUCTION=False

# --- Telemetry sinks (never required for adjudication correctness) ---
# STRATEGY_VALIDATOR_TELEMETRY_JSONL_PATH=C:/absolute/path/telemetry.jsonl
# STRATEGY_VALIDATOR_TELEMETRY_HTTP_URL=https://collector.example.invalid/telemetry
# STRATEGY_VALIDATOR_TELEMETRY_HTTP_TIMEOUT_SECONDS=5
# STRATEGY_VALIDATOR_TELEMETRY_HTTP_MAX_RETRIES=3
# STRATEGY_VALIDATOR_TELEMETRY_HTTP_BACKOFF_START_MS=100
# STRATEGY_VALIDATOR_TELEMETRY_HTTP_BEARER_TOKEN_ENV=MY_TELEMETRY_BEARER
# MY_TELEMETRY_BEARER=
# STRATEGY_VALIDATOR_TELEMETRY_HTTP_AUTH_HEADER=X-Custom-Auth: secret-value

# --- Runtime metrics (optional; failures are logged only) ---
# STRATEGY_VALIDATOR_METRICS_TEXTFILE_PATH=C:/var/lib/node_exporter/textfile_collector/strategy_validator.prom
# STRATEGY_VALIDATOR_METRICS_PUSHGATEWAY_URL=https://pushgateway.example.invalid
# STRATEGY_VALIDATOR_METRICS_PUSH_JOB=strategy_validator
