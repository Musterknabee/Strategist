# Strategy Validator single-tenant backend deployment environment.
# Bootstrap a real copy (dirs + migrate + tokens): python scripts/setup_local_deployment.py
# Or copy manually to deployment.env and replace every CHANGEME value.
# Validate the real copy with: strategy-validator-deployment-env-check deployment.env --require-valid --json
# Do not commit real tokens or private signing keys.

STRATEGY_VALIDATOR_MODE=PRODUCTION
STRATEGY_VALIDATOR_API_TOKEN=CHANGEME-minimum-32-random-characters
STRATEGY_VALIDATOR_API_TOKEN_SCOPES=operator:command:write,operator:projection:read
# Optional: separate research/advisory ingress token. If unset, research routes fall back to mutation token compatibility.
STRATEGY_VALIDATOR_RESEARCH_API_TOKEN=CHANGEME-separate-research-token

STRATEGY_VALIDATOR_LEDGER_DB_PATH=/var/lib/strategy-validator/ledger.sqlite3
STRATEGY_VALIDATOR_LEDGER_BACKUP_DIR=/var/backups/strategy-validator
STRATEGY_VALIDATOR_ARTIFACT_ROOT=/var/lib/strategy-validator/artifacts

# Optional loopback host port used by generated Compose/systemd and API smoke.
STRATEGY_VALIDATOR_HOST_PORT=8000

# Optional comma-separated browser origins allowed to call read-plane GET/HEAD/OPTIONS against /ui/*
# (e.g. Next.js dev server). Leave unset for default same-origin or reverse-proxy setups.
# STRATEGY_VALIDATOR_UI_CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# Keep optional mutation throttling enabled when the API is exposed beyond localhost.
STRATEGY_VALIDATOR_API_MUTATION_RATE_LIMIT_PER_MINUTE=60

# --- Optional research / data providers (never required for API startup) ---
# Copy placeholders only; real keys belong in deployment.env or .env.local (gitignored).

# SEC EDGAR (descriptive User-Agent; not a cryptographic secret)
# SEC_USER_AGENT=YourOrg contact@example.com

# Macro / official (keys optional)
# FRED_API_KEY=
# BLS_API_KEY=

# Market data / fundamentals
# ALPHA_VANTAGE_API_KEY=
# FINNHUB_API_KEY=
# FMP_API_KEY=
# TWELVE_DATA_API_KEY=
