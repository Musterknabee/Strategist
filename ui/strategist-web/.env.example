# Public browser config only — never put API tokens here.
#
# Production: set explicitly to your API origin (often same site with reverse proxy).
# Example: https://ops.example.com
NEXT_PUBLIC_STRATEGIST_API_BASE_URL=http://127.0.0.1:8000
#
# Offline cockpit preview only. Must remain opt-in; demo data is synthetic and
# never represents readiness, deployment approval, signoff, or live execution.
# NEXT_PUBLIC_STRATEGIST_DEMO_MODE=true
#
# Split-origin dev (browser at :3000, API at :8000): the backend must opt in to CORS for
# read-plane GET/HEAD/OPTIONS on /ui/*. Set on the API host (e.g. deployment.env), not here:
#   STRATEGY_VALIDATOR_UI_CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# Optional smoke script (scripts/smoke-ui.mjs) and scripts/verify_frontend.py
# STRATEGIST_SMOKE_API_BASE_URL=http://127.0.0.1:8000
