# Base URL of the FastAPI service exposing the Strategist `/ui/*` routes.
# Example: http://localhost:8000
STRATEGIST_BACKEND_BASE_URL=http://localhost:8000

# Optional fetch timeout for the Next.js BFF -> backend hop in milliseconds.
STRATEGIST_BACKEND_TIMEOUT_MS=5000

# Force the frontend BFF to use local mock payloads even when a backend base URL is set.
STRATEGIST_FORCE_MOCKS=false

# Optional base URL for local smoke probing
STRATEGIST_WEB_BASE_URL=http://localhost:3000

STRATEGIST_BACKEND_BASE_URL=http://localhost:8000
STRATEGIST_BACKEND_TIMEOUT_MS=5000
STRATEGIST_FORCE_MOCKS=false
STRATEGIST_STRICT_BACKEND=true
