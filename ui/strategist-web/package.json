{
  "name": "strategist-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "smoke": "node ./scripts/smoke-frontend.mjs",
    "contract:check": "python ../../scripts/frontend_ui_contract_check.py",
    "contract:generate": "python ../../scripts/generate_frontend_ui_facade_contract.py",
    "acceptance": "vitest run tests",
    "validate": "npm run contract:check && npm run lint && npm run typecheck && npm run test && npm run acceptance && npm run build",
    "audit": "npm audit --audit-level=high",
    "certify": "node ./scripts/certify.mjs"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.8",
    "next": "15.5.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "overrides": {
    "postcss": "8.5.13"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "eslint": "^8.57.0",
    "eslint-config-next": "15.5.18",
    "@testing-library/react": "^16.0.1",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
